# ─── Taraa Admin Panel — Environment Template ─────────────────────────────────
# Copy this file to .env.development / .env.staging / .env.production
# and fill in values for each environment.
# Never commit .env.local or .env.*.local — those hold secrets.

# ── App ────────────────────────────────────────────────────────────────────────
# development | staging | production
NEXT_PUBLIC_APP_ENV=

# Public URL of this admin panel
# dev:     http://localhost:3002
# staging: https://admin-staging.taraa.in
# prod:    https://taraa-admin.vercel.app
NEXT_PUBLIC_APP_URL=

# ── Backend API ────────────────────────────────────────────────────────────────
# Points to the environment-specific backend (which connects to that env's DB)
# dev:     http://localhost:3001/api/v1       → taraa_dev database
# staging: https://api-staging.taraa.in/api/v1 → taraa_staging database
# prod:    https://api.taraa.in/api/v1          → taraa_production database
NEXT_PUBLIC_API_URL=

# ── Admin ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=

# ── Logging ────────────────────────────────────────────────────────────────────
# true in dev/staging, false in production
NEXT_PUBLIC_ENABLE_LOGS=
