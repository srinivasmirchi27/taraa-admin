# ─── Staging Environment ──────────────────────────────────────────────────────
# Backend points to staging server
# Database: taraa_staging (isolated staging DB — mirrors prod schema, not prod data)

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_URL=https://admin-staging.taraa.in

NEXT_PUBLIC_API_URL=https://api-staging.taraa.in/api/v1

NEXT_PUBLIC_ADMIN_EMAIL=admin@taraa.in

NEXT_PUBLIC_ENABLE_LOGS=true
