{
  "name": "taraa-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "dev:staging": "NODE_ENV=development NEXT_PUBLIC_APP_ENV=staging next dev --port 3002",
    "build": "next build",
    "build:staging": "NODE_ENV=production dotenv -e .env.staging -- next build",
    "build:production": "NODE_ENV=production dotenv -e .env.production -- next build",
    "start": "next start --port 3002",
    "start:staging": "NODE_ENV=production dotenv -e .env.staging -- next start --port 3002",
    "start:production": "NODE_ENV=production dotenv -e .env.production -- next start --port 3002",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
